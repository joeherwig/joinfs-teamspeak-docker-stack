# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.
# On Hetzner, an equivalent file is written automatically by hetzner-cloud-config.yaml.

# MariaDB root password — shared between the db and teamspeak containers.
DB_ROOT_PASSWORD=CHANGEME

# TeamSpeak serveradmin password — MUST be set before the very first
# `docker compose up` if you're using TS3_CONFIG below (the official image only
# generates a random password on first boot when none is pre-set here, and
# ts3init.py needs a working login from its first connection attempt to
# provision anything — see README "First boot"). tsapi also authenticates to
# TS3 ServerQuery with this same value.
TS3_SERVERADMIN_PASSWORD=CHANGEME

# Declarative TeamSpeak server + channel setup (optional). Applied by ts3init.py
# on every start as a create-or-update sync: existing channels are updated in
# place to match this (not duplicated), while channels removed from here or
# created manually in a TeamSpeak client are left alone — never deleted. Leave
# unset for today's default behavior (no channels, default TS3 server settings).
#
# Must be valid single-line JSON. Single-quoted here so the JSON's own double
# quotes don't need escaping — avoid literal single-quote characters inside the
# JSON content itself (e.g. an apostrophe in a welcome message), since that
# would end this value early; use the Unicode right single quote ’ instead,
# or just avoid apostrophes.
# See README "Server and channel provisioning" for the full field reference.
#
# Uncomment and edit the example below (every field is optional):
# TS3_CONFIG='{"server":{"name":"My Flightsim ATC","password":"letmein","welcome_message":"Welcome to [b]ATC HQ[/b]!","hostbanner":{"url":"https://example.com","gfx_url":"https://example.com/banner.png","mode":1},"allow_client_chat":true},"channels":[{"name":"ATC - Tower","topic":"atc-tower","type":"permanent"},{"name":"Pilot Lounge","type":"permanent","password":"flyhigh"},{"name":"Staff Only","type":"semi_permanent","password":"secret"}]}'

# JoinFS hub settings — shown in the public JoinFS hub list.
JOINFS_HUB_NAME=My JoinFS Hub
# Public IP or hostname of this server — run: curl -s https://api.ipify.org
JOINFS_HUB_DOMAIN=

# Public domain name for the Caddy TLS reverse proxy (e.g. joinfs.example.com).
# Must have a DNS A/AAAA record pointing at this server, with ports 80 and 443
# reachable from the internet — Caddy uses port 80 for the Let's Encrypt ACME
# challenge and serves the WebSocket (/ws/) and tsapi routes over 443.
CADDY_DOMAIN=

# Whether tsapi's state-changing routes (/channel, /move, /usertochannel) are
# reachable from the public internet via Caddy. Default false: Caddy returns
# 404 for them — JoinFS itself is unaffected, since it calls tsapi over the
# internal Docker network directly, never through Caddy. Set to true only if
# you understand there is still no authentication on these routes once open.
TSAPI_EXPOSE_WRITE_ENDPOINTS=false

# Docker Hub account that publishes the prebuilt tsapi/joinfs-console images.
# Only change this if you fork this repo and publish your own images under a
# different account.
DOCKERHUB_USERNAME=joeherwig

# Optional: set to 1 to enable Flask debug/auto-reload on tsapi (local development only).
FLASK_DEBUG=0
