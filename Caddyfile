{$CADDY_DOMAIN} {
	# JoinFS live aircraft WebSocket feed, exposed at /ws/ and proxied to the
	# JoinFS hub's websocket listener at its own root path.
	handle_path /ws/* {
		reverse_proxy joinfs:8765
	}

	# Read-only tsapi routes are public by default.
	@apiRead {
		method GET
		path /users* /channels*
	}
	handle @apiRead {
		reverse_proxy tsapi:8081
	}

	# State-changing tsapi routes (create channels, move clients, the JoinFS
	# webhook target) are closed to the public internet by default — tsapi has
	# no authentication, and JoinFS itself calls /usertochannel over the internal
	# Docker network directly (see compose.yaml), never through Caddy, so nothing
	# legitimate needs this exposed externally. Set TSAPI_EXPOSE_WRITE_ENDPOINTS=true
	# in .env (and restart caddy) to expose them publicly anyway — there is still
	# no authentication on these routes once open, so only do this if you
	# understand and accept that risk.
	@apiWrite {
		method PUT POST
		path /usertochannel* /channel* /move*
		expression `"{$TSAPI_EXPOSE_WRITE_ENDPOINTS}" == "true"`
	}
	handle @apiWrite {
		reverse_proxy tsapi:8081
	}

	handle {
		respond "Not Found" 404
	}
}
